# Canonical source-controlled asset pipeline files live under assets/shaders.
# Local development textures/images under assets/textures are machine-local and must not be committed.
# Mutable runtime data belongs under Runtime/ and must not be committed.

# Private/local assets
/assets/*
!/assets/.gitkeep
!/assets/shaders/
!/assets/shaders/**
!/assets/textures/
/assets/textures/**
!/assets/textures/.gitkeep

# Owner-only / confidential materials
/owners/
/Governance/owners/
/secrets/
/private/

# Secret-bearing local files
/.env
/.env.*
*.pem
*.key
*.p12
*.crt
*.cer
*.ovpn

# Runtime-only mutable state
/Runtime/**
!/Runtime/
!/Runtime/Config/
!/Runtime/Config/.gitkeep
!/Runtime/Logs/
!/Runtime/Logs/.gitkeep
!/Runtime/Saves/
!/Runtime/Saves/.gitkeep
!/Runtime/CrashDumps/
!/Runtime/CrashDumps/.gitkeep
!/Runtime/Host/
!/Runtime/Host/.gitkeep

# Packaging outputs
/Packaging/output/
/Packaging/staging/

# Build folders
/build/
/out/
/bin/
/obj/
/x64/
/Debug/
/Release/
/.vs/
/.vscode/ipch/

# Build outputs
*.dll
*.exe
*.exp
*.idb
*.ilk
*.lib
*.manifest
*.obj
*.o
*.pch
*.pdb
*.tlog

# CMake
CMakeUserPresets.json
CMakeCache.txt
CMakeFiles/
cmake-build-*/
compile_commands.json

# Visual Studio / IDE
*.VC.db
*.VC.opendb
*.opensdf
*.sdf
*.suo
*.user
*.userosscache
*.ipch
.idea/

# Logs / temp
*.bak
*.log
*.tmp
.DS_Store
Thumbs.db
