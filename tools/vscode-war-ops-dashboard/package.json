{
  "name": "war-ops-dashboard",
  "displayName": "WAR Ops: Dashboard",
  "description": "Operations dashboard for the WAR package, launch, and milestone validation lanes through M50.",
  "version": "0.0.1",
  "publisher": "imperator-local",
  "engines": {
    "vscode": "^1.111.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:warOps.panel",
    "onCommand:warOps.openDashboard",
    "onCommand:warOps.focusPanel",
    "onCommand:warOps.refresh",
    "onCommand:warOps.openOutput"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "warOps.openDashboard",
        "title": "WAR Ops: Dashboard: Open Dashboard"
      },
      {
        "command": "warOps.focusPanel",
        "title": "WAR Ops: Dashboard: Focus Panel"
      },
      {
        "command": "warOps.refresh",
        "title": "WAR Ops: Dashboard: Refresh Status"
      },
      {
        "command": "warOps.openOutput",
        "title": "WAR Ops: Dashboard: Open Output"
      },
      {
        "command": "warOps.action.buildPackageRelease",
        "title": "WAR Ops: Dashboard: Package Release"
      },
      {
        "command": "warOps.action.buildPackageDebug",
        "title": "WAR Ops: Dashboard: Package Debug"
      },
      {
        "command": "warOps.action.buildBetaCandidateRelease",
        "title": "WAR Ops: Dashboard: Package Beta"
      },
      {
        "command": "warOps.action.buildMarketCandidateRelease",
        "title": "WAR Ops: Dashboard: Package Market"
      },
      {
        "command": "warOps.action.buildShadersDebug",
        "title": "WAR Ops: Dashboard: Build Shaders Debug"
      },
      {
        "command": "warOps.action.buildShadersRelease",
        "title": "WAR Ops: Dashboard: Build Shaders Release"
      },
      {
        "command": "warOps.action.launchHeadlessHost",
        "title": "WAR Ops: Dashboard: Launch Headless Host"
      },
      {
        "command": "warOps.action.launchLocalDemo",
        "title": "WAR Ops: Dashboard: Launch Local Demo"
      },
      {
        "command": "warOps.action.launchClientAgainstHost",
        "title": "WAR Ops: Dashboard: Launch Client + Host"
      },
      {
        "command": "warOps.action.smokeHost",
        "title": "WAR Ops: Dashboard: Smoke Host"
      },
      {
        "command": "warOps.action.smokeLocalDemo",
        "title": "WAR Ops: Dashboard: Smoke Client"
      },
      {
        "command": "warOps.action.validateM45InternalAlpha",
        "title": "WAR Ops: Dashboard: Validate M45"
      },
      {
        "command": "warOps.action.validateM46InternalAlpha",
        "title": "WAR Ops: Dashboard: Validate M46"
      },
      {
        "command": "warOps.action.validateM47InternalAlpha",
        "title": "WAR Ops: Dashboard: Validate M47"
      },
      {
        "command": "warOps.action.validateM48InternalAlpha",
        "title": "WAR Ops: Dashboard: Validate M48"
      },
      {
        "command": "warOps.action.validateM49BetaCandidate",
        "title": "WAR Ops: Dashboard: Validate M49"
      },
      {
        "command": "warOps.action.validateM50MarketCandidate",
        "title": "WAR Ops: Dashboard: Validate M50"
      },
      {
        "command": "warOps.action.openReadme",
        "title": "WAR Ops: Dashboard: Open Readme"
      },
      {
        "command": "warOps.action.openRuntimeBoundary",
        "title": "WAR Ops: Dashboard: Open Runtime Boundary"
      },
      {
        "command": "warOps.action.openRunway",
        "title": "WAR Ops: Dashboard: Open Runway"
      },
      {
        "command": "warOps.action.openM48Milestone",
        "title": "WAR Ops: Dashboard: Open M48 Milestone"
      },
      {
        "command": "warOps.action.openM49Milestone",
        "title": "WAR Ops: Dashboard: Open M49 Milestone"
      },
      {
        "command": "warOps.action.openM50Milestone",
        "title": "WAR Ops: Dashboard: Open M50 Milestone"
      },
      {
        "command": "warOps.action.openM48Evidence",
        "title": "WAR Ops: Dashboard: Open M48 Evidence"
      },
      {
        "command": "warOps.action.openM49Evidence",
        "title": "WAR Ops: Dashboard: Open M49 Evidence"
      },
      {
        "command": "warOps.action.openM50Evidence",
        "title": "WAR Ops: Dashboard: Open M50 Evidence"
      },
      {
        "command": "warOps.action.openRoadmap",
        "title": "WAR Ops: Dashboard: Open Roadmap"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "warOps",
          "title": "WAR Ops",
          "icon": "media/activity-icon.svg"
        }
      ]
    },
    "views": {
      "warOps": [
        {
          "id": "warOps.panel",
          "name": "Dashboard",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "warOps.refresh",
          "when": "view == warOps.panel",
          "group": "navigation"
        }
      ]
    }
  }
}
